(* Beginning of Notebook Content *)
Notebook[{

Cell["Quantum Shuffle Algebra Package", "Section"],

Cell["\<\
Author: Eremey Valetov
Email: eremey@valetov.com

This notebook demonstrates the QuantumShuffleAlgebra package.
The package source is in QuantumShuffleAlgebra.wl.
For a script-based demo, see examples/BasicUsage.wl.\
\>", "Text"],

Cell["Setup", "Subsection"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Get", "[", "\"\<QuantumShuffleAlgebra`\>\"", "]"}], ";"}]
], "Input"],

Cell["Lyndon Word Operations", "Subsection"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"a", "=",
   RowBox[{"{",
    RowBox[{"18", ",", "19", ",", "4", ",", "8", ",", "5", ",", "7"}], "}"}]
  }], ";"}], "\n",
 RowBox[{"QSAIsPrime", "[", "a", "]"}]}], "Input"],

Cell[BoxData[
 RowBox[{"QSAUniquePrimeFactorization", "[", "a", "]"}]
], "Input"],

Cell[BoxData[
 RowBox[{"QSAX", "[", "a", "]"}]
], "Input"],

Cell["Shuffle Multiplication", "Subsection"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"b", "=",
   RowBox[{"{",
    RowBox[{"10", ",", "7", ",", "2"}], "}"}]}], ";"}], "\n",
 RowBox[{
  RowBox[{"c", "=",
   RowBox[{"{",
    RowBox[{"5", ",", "4", ",", "5"}], "}"}]}], ";"}], "\n",
 RowBox[{"QSAShuffleMultiplication", "[",
  RowBox[{"{",
   RowBox[{"b", ",", "c"}], "}"}], "]"}]}], "Input"],

Cell["Express in Lyndon Word Basis", "Subsection"],

Cell[BoxData[
 RowBox[{"QSAExpressInLyndonWords", "[", "a", "]"}]
], "Input"],

Cell[BoxData[
 RowBox[{"QSAPrimaryCoefficient", "[", "a", "]"}]
], "Input"],

Cell["Lyndon Word Enumeration", "Subsection"],

Cell[BoxData[
 RowBox[{"QSALyndonWords", "[",
  RowBox[{"3", ",",
   RowBox[{"{",
    RowBox[{"1", ",", "2"}], "}"}]}], "]"}]
], "Input"],

Cell["Hopf Algebra Operations", "Subsection"],

Cell[BoxData[{
 RowBox[{"QSACoproduct", "[",
  RowBox[{"{", "1", "}"}], "]"}], "\n",
 RowBox[{"QSACoproduct", "[",
  RowBox[{"{",
   RowBox[{"1", ",", "2"}], "}"}], "]"}], "\n",
 RowBox[{"QSACounit", "[",
  RowBox[{"{", "}"}], "]"}], "\n",
 RowBox[{"QSACounit", "[",
  RowBox[{"{", "1", "}"}], "]"}], "\n",
 RowBox[{"QSAAntipode", "[",
  RowBox[{"{", "1", "}"}], "]"}]}], "Input"],

Cell["Braiding", "Subsection"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"qMat", "=",
   RowBox[{"{",
    RowBox[{
     RowBox[{"{",
      RowBox[{"1", ",", "2"}], "}"}], ",",
     RowBox[{"{",
      RowBox[{"3", ",", "1"}], "}"}]}], "}"}]}], ";"}], "\n",
 RowBox[{"QSABraid", "[",
  RowBox[{
   RowBox[{"{", "1", "}"}], ",",
   RowBox[{"{", "2", "}"}], ",", "qMat"}], "]"}]}], "Input"]
},
WindowSize->{808, 685},
WindowMargins->{{4, Automatic}, {Automatic, 4}},
FrontEndVersion->"14.0 for Linux x86 (64-bit)",
StyleDefinitions->"Default.nb"
]
(* End of Notebook Content *)
